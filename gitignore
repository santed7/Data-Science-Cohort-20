# ---- OTQ Dashboard: keep build junk out of the repo and the trial zip ----

# Python virtual environments (regenerated by the launchers)
venv/
.venv/
env/

# PyInstaller build output (regenerated by Build Windows EXE.bat)
build/
dist/
*.spec.bak

# Python bytecode / caches
__pycache__/
*.py[cod]
*.pyc
*.pyo

# Runtime output (charts/metrics the app writes while running)
static/out/
otq_dashboard_out/
*.log

# OS / editor clutter
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/

# Local trial-state files (per-user; never commit)
*.otqlic

# Stray archives you don't want tracked
# (comment out the next line if you DO want to commit a zip)
*.zip
